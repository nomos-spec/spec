{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nomosprotocol.com/schema/artifact.schema.json",
  "title": "NOMOS Artifact",
  "description": "A sealed .nomos governance artifact conforming to NOMOS-SPEC-001",
  "type": "object",
  "required": [
    "artifact_id",
    "version",
    "spec_version",
    "confidence",
    "domain",
    "rules",
    "contradiction_report",
    "readiness",
    "seal"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,128}$",
      "description": "URL-safe identifier, unique within an organisation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (MAJOR.MINOR.PATCH)"
    },
    "spec_version": {
      "type": "string",
      "enum": ["NOMOS-SPEC-001", "NOMOS-SPEC-002", "NOMOS-SPEC-003", "NOMOS-SPEC-004"],
      "description": "Protocol specification version this artifact conforms to"
    },
    "confidence": {
      "type": "string",
      "enum": ["DECLARED", "VALIDATED", "CERTIFIED"],
      "description": "DECLARED = policy-only; VALIDATED = confirmed against behavioral data, contradiction detection passed; CERTIFIED = full triangulation and gap analysis passed"
    },
    "conflict_resolution": {
      "type": "string",
      "enum": ["first_match", "collect_and_resolve", "highest_priority"],
      "default": "first_match",
      "description": "How conflicting matching rules are resolved during execution"
    },
    "domain": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "organization": { "type": "string" },
        "effective_date": { "type": "string", "format": "date" },
        "jurisdiction": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "rule.schema.json" },
      "description": "Ordered array of governance rules"
    },
    "contradiction_report": {
      "type": "object",
      "required": ["contradiction_count", "contradictions"],
      "additionalProperties": false,
      "properties": {
        "contradiction_count": {
          "type": "integer",
          "minimum": 0
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "rule_ids", "description", "severity"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "threshold_conflict",
                  "role_conflict",
                  "ghost_term",
                  "rule_collision",
                  "layer_divergence"
                ]
              },
              "rule_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        }
      }
    },
    "readiness": {
      "type": "object",
      "required": ["lis", "res", "gms", "ari", "autonomy_band"],
      "additionalProperties": false,
      "properties": {
        "lis": { "type": "number", "minimum": 0, "maximum": 1 },
        "drs": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ],
          "description": "null for DECLARED artifacts; float for VALIDATED and CERTIFIED"
        },
        "res": { "type": "number", "minimum": 0, "maximum": 1 },
        "gms": { "type": "number", "minimum": 0, "maximum": 1 },
        "ari": { "type": "number", "minimum": 0, "maximum": 1 },
        "autonomy_band": {
          "type": "string",
          "enum": ["autonomous", "bounded", "human_governed"]
        }
      }
    },
    "data_contract": {
      "type": "object",
      "description": "Declares the minimum context fields required for evaluation (§3.9). Absence of any required_field triggers a data_contract_violation error.",
      "additionalProperties": false,
      "properties": {
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Context field paths that MUST be present in every execution request"
        },
        "field_types": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["string", "number", "boolean", "array", "object"]
          },
          "description": "Optional type hints per field — informational only; runtimes MUST NOT coerce values"
        }
      }
    },
    "seal": {
      "type": "object",
      "description": "The cryptographic seal (§8). Ed25519 (asymmetric) is RECOMMENDED and publicly verifiable; HMAC-SHA256 (symmetric) is legacy and not third-party verifiable.",
      "oneOf": [
        {
          "title": "Asymmetric seal (RECOMMENDED, publicly verifiable)",
          "required": ["signature_algorithm", "hash", "signed_by", "signature"],
          "properties": {
            "status": { "type": "string", "const": "sealed" },
            "canonicalization": { "type": "string", "const": "JCS" },
            "signature_algorithm": { "type": "string", "enum": ["Ed25519", "RS256", "ES256"] },
            "kid": { "type": "string", "description": "Key id of the signing key; selects the public key at /.well-known/nomos-signing-keys" },
            "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$", "description": "Lowercase hex SHA-256 of the canonical payload (excluding seal)" },
            "signed_by": {
              "type": "object",
              "required": ["name", "org_id", "role", "timestamp"],
              "properties": {
                "name": { "type": "string" },
                "org_id": { "type": "string" },
                "role": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" }
              }
            },
            "signature": { "type": "string", "description": "base64 signature over JCS({hash, signed_by})" }
          }
        },
        {
          "title": "Legacy HMAC seal (symmetric, not third-party verifiable)",
          "required": ["hash"],
          "properties": {
            "status": { "type": "string", "const": "sealed" },
            "canonicalization": { "type": "string", "const": "JCS" },
            "algorithm": { "type": "string", "const": "HMAC-SHA256" },
            "signature_algorithm": { "type": "string", "const": "HMAC-SHA256" },
            "ts": { "type": "string", "format": "date-time" },
            "signed_by": { "type": "object" },
            "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "sig": { "type": "string", "pattern": "^[0-9a-f]{64}$", "description": "Lowercase hex HMAC-SHA256(SEAL_KEY, hash)" },
            "signature": { "type": "string" }
          }
        }
      ]
    },
    "composition": {
      "type": "object",
      "description": "Composition provenance (NOMOS-SPEC-004 §1.3). Present on artifacts produced by extending a base artifact. Written before sealing and therefore covered by the seal.",
      "required": ["extends", "parent_rule_count", "inherited", "overridden", "removed", "local", "composed_at"],
      "additionalProperties": false,
      "properties": {
        "extends": {
          "type": "object",
          "required": ["artifact_id", "version"],
          "additionalProperties": false,
          "properties": {
            "artifact_id": { "type": "string" },
            "version": { "type": "string" },
            "seal_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }], "description": "The base version's seal hash, pinning exactly what was inherited" }
          }
        },
        "parent_rule_count": { "type": "integer", "minimum": 0 },
        "inherited": { "type": "array", "items": { "type": "string" }, "description": "Base rule ids kept verbatim" },
        "overridden": { "type": "array", "items": { "type": "string" }, "description": "Base rule ids replaced by a same-id child rule" },
        "removed": { "type": "array", "items": { "type": "string" }, "description": "Base rule ids dropped" },
        "local": { "type": "array", "items": { "type": "string" }, "description": "Child-only rule ids (no base counterpart)" },
        "composed_at": { "type": "string", "format": "date-time" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "attestations": {
      "type": "array",
      "description": "Third-party co-signatures (NOMOS-SPEC-004 §2). Added AFTER sealing by parties other than the issuer, and EXCLUDED from the seal-hash computation — the seal covers the artifact minus both `seal` and `attestations`.",
      "items": {
        "type": "object",
        "required": ["attester", "statement", "artifact_hash", "artifact_version", "algorithm", "kid", "signature", "attested_at"],
        "additionalProperties": false,
        "properties": {
          "attester": {
            "type": "object",
            "required": ["name", "org_id", "role"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "org_id": { "type": "string" },
              "role": { "type": "string", "description": "e.g. regulator | auditor | authority" }
            }
          },
          "statement": { "type": "string" },
          "artifact_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$", "description": "MUST equal the artifact's seal.hash (binds to this version)" },
          "artifact_version": { "type": "string" },
          "algorithm": { "type": "string", "const": "Ed25519" },
          "kid": { "type": "string", "description": "Attester public-key id; resolves at /.well-known/nomos-signing-keys" },
          "signature": { "type": "string", "description": "base64 Ed25519 over JCS({artifact_hash, artifact_version, attester, statement, attested_at})" },
          "attested_at": { "type": "string", "format": "date-time" },
          "revoked_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] }
        }
      }
    }
  }
}
